# ============================================================
# Streaming Distribuido — Variables de Entorno
# ============================================================
# Este archivo es solo de referencia.
# deploy.sh genera el .env automáticamente según MACHINE_ID.
# ============================================================

# Identidad de esta máquina física
MACHINE_ID=3                  # 1 (frontend) | 2 (gateway) | 3, 4, 5 (nodos)
MACHINE_ROLE=node             # frontend | gateway | node

# Solo relevante si MACHINE_ROLE=node
GALERA_CLUSTER_ADDRESS=gcomm://192.168.1.13,192.168.1.14,192.168.1.15
GALERA_NODE_NAME=nodo3
GALERA_NODE_ADDRESS=192.168.1.13

# Direcciones de red (todas las máquinas)
GATEWAY_HOST=192.168.1.12
NODE_HOSTS=192.168.1.13,192.168.1.14,192.168.1.15
REDIS_HOST=192.168.1.12
REDIS_PORT=6379

# Puertos de servicio (iguales en los 3 nodos)
USUARIOS_PORT=8081
RECOMENDACIONES_PORT=8082
PAGOS_PORT=8083
MARIADB_PORT=3306
